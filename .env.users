# ============================================
# SupportEnv - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ===================
# Required Settings
# ===================
HOST=0.0.0.0
PORT=7860

# ===================
# Optional: OpenAI API (for LLM baseline)
# ===================
# OPENAI_API_KEY=sk-your-key-here

# ===================
# Optional: HuggingFace (for deployment)
# ===================
# HF_TOKEN=hf_your-token-here
# HF_SPACE_ID=username/support-env

# ===================
# Environment URL
# ===================
# Local development
SUPPORT_ENV_URL=http://localhost:7860

# Production (uncomment for deployed version)
# SUPPORT_ENV_URL=https://username-support-env.hf.space