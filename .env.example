# ============================================
# SupportEnv - Environment Variables
# ============================================

# ===================
# Server Configuration
# ===================
HOST=0.0.0.0
PORT=7860
WORKERS=1
DEBUG=false
LOG_LEVEL=info

# ===================
# Environment Settings
# ===================
ENVIRONMENT=production
# Options: development, staging, production

# Max concurrent WebSocket sessions
MAX_CONCURRENT_ENVS=100

# Default random seed (for reproducibility)
DEFAULT_SEED=42

# ===================
# OpenAI API (for LLM Baseline)
# ===================
# Required only if running LLM baseline
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=200

# ===================
# HuggingFace Configuration
# ===================
HF_TOKEN=hf_your-huggingface-token-here
HF_SPACE_URL=https://username-support-env.hf.space

# Space ID for deployment
HF_SPACE_ID=username/support-env

# ===================
# Environment URLs
# ===================
# Used by Gradio frontend and client
SUPPORT_ENV_URL=http://localhost:7860

# For production (HF Spaces)
# SUPPORT_ENV_URL=https://username-support-env.hf.space

# ===================
# Grading Configuration
# ===================
# Strict mode fails on any grader error
GRADING_STRICT_MODE=true

# Enable detailed grading logs
GRADING_VERBOSE=false

# ===================
# Baseline Configuration
# ===================
BASELINE_SEEDS=42,123,456
BASELINE_OUTPUT_PATH=baseline/results.json
BASELINE_VERBOSE=false

# ===================
# Logging
# ===================
LOG_FORMAT=json
# Options: json, text

LOG_FILE=logs/support_env.log
ENABLE_FILE_LOGGING=false

# ===================
# Security
# ===================
# API key for protected endpoints (optional)
API_SECRET_KEY=your-secret-key-here

# CORS origins (comma-separated)
CORS_ORIGINS=*

# ===================
# Rate Limiting (optional)
# ===================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===================
# Database (optional, for episode logging)
# ===================
# DATABASE_URL=sqlite:///./episodes.db
# DATABASE_URL=postgresql://user:pass@localhost/supportenv

# ===================
# Redis (optional, for session management)
# ===================
# REDIS_URL=redis://localhost:6379/0

# ===================
# Monitoring (optional)
# ===================
# SENTRY_DSN=https://your-sentry-dsn
# PROMETHEUS_ENABLED=false
# PROMETHEUS_PORT=9090